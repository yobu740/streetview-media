{
  "query": "\n-- Check all instalaciones Programado with their anuncio estado\nSELECT \n  i.id as instalacion_id,\n  i.estado as inst_estado,\n  a.id as anuncio_id,\n  a.estado as anuncio_estado,\n  a.producto,\n  a.cliente,\n  p.cobertizo_id,\n  p.flow_cat,\n  p.orientacion\nFROM instalaciones i\nJOIN anuncios a ON i.anuncio_id = a.id\nJOIN paradas p ON i.parada_id = p.id\nWHERE i.estado = 'Programado'\nORDER BY a.estado, a.cliente, p.cobertizo_id;\n",
